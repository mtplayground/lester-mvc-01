# Application
NODE_ENV=development

# Server
PORT=3000
JWT_SECRET=replace-with-a-secure-random-secret
JWT_EXPIRES_IN=7d

# Database (local/dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lester_mvc?schema=public
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lester_mvc_test?schema=public

# Frontend
VITE_API_BASE_URL=http://localhost:3000/api

# Docker Compose Postgres defaults
POSTGRES_DB=lester_mvc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
